# ──────────────────────────────────────────────────────────
# ElectionGuide AI — Environment Variables
# ──────────────────────────────────────────────────────────
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────

# ─── Required ────────────────────────────────────────────

# Google Gemini API key (get free at https://aistudio.google.com)
GEMINI_API_KEY=

# ─── Optional (defaults are provided) ────────────────────

# Server port (Cloud Run injects this automatically)
PORT=8080

# Node environment
NODE_ENV=development

# Google Cloud project ID
PROJECT_ID=promptwars-493516

# Gemini model (default: gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash

# Rate limiting (requests per 15-minute window)
RATE_LIMIT_GLOBAL=100
RATE_LIMIT_AI=20
