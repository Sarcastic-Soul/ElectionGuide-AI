{
  "name": "electionguide-ai",
  "version": "1.0.0",
  "description": "AI-powered Election Process Education Assistant built with Google Cloud services",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest --forceExit --detectOpenHandles",
    "test:coverage": "jest --coverage --forceExit --detectOpenHandles",
    "test:watch": "jest --watch --forceExit",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "format": "prettier --write \"src/**/*.js\" \"tests/**/*.js\"",
    "validate": "npm run lint && npm test"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "election",
    "education",
    "ai",
    "gemini",
    "google-cloud",
    "civic-education"
  ],
  "author": "ElectionGuide AI Team",
  "license": "MIT",
  "dependencies": {
    "@google-cloud/firestore": "^7.11.0",
    "@google-cloud/logging": "^11.2.0",
    "@google-cloud/text-to-speech": "^5.5.0",
    "@google-cloud/translate": "^8.5.0",
    "@google/genai": "^1.0.0",
    "compression": "^1.7.5",
    "dompurify": "^3.2.4",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "express-validator": "^7.2.1",
    "helmet": "^8.0.0",
    "jsdom": "^26.0.0",
    "lru-cache": "^11.0.2",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "eslint": "^9.17.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.9",
    "prettier": "^3.4.2",
    "supertest": "^7.0.0"
  }
}
