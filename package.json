{
  "name": "electionguide-ai",
  "version": "1.0.0",
  "description": "AI-powered Election Process Education Assistant built with Google Cloud services",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --detectOpenHandles",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage --detectOpenHandles",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "test:e2e": "playwright test",
    "test:load": "node tests/performance/load.js",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "format": "prettier --write \"src/**/*.js\" \"tests/**/*.js\"",
    "validate": "npm run lint && npm test"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "election",
    "education",
    "ai",
    "gemini",
    "google-cloud",
    "civic-education"
  ],
  "author": "ElectionGuide AI Team",
  "license": "MIT",
  "dependencies": {
    "@google-cloud/firestore": "^8.5.0",
    "@google-cloud/logging": "^11.2.1",
    "@google-cloud/monitoring": "^5.3.1",
    "@google-cloud/secret-manager": "^6.1.1",
    "@google-cloud/text-to-speech": "^5.5.0",
    "@google-cloud/trace-agent": "^8.0.0",
    "@google-cloud/translate": "^9.3.0",
    "@google/genai": "^1.0.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "express-validator": "^7.2.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.3",
    "lru-cache": "^11.0.2",
    "rate-limit-redis": "^4.3.1",
    "redis": "^5.12.1",
    "sanitize-html": "^2.17.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "autocannon": "^8.0.0",
    "eslint": "^9.17.0",
    "globals": "^17.5.0",
    "jest": "^29.7.0",
    "jest-axe": "^10.0.0",
    "jest-environment-jsdom": "^30.3.0",
    "nodemon": "^3.1.9",
    "prettier": "^3.4.2",
    "supertest": "^7.0.0"
  },
  "overrides": {
    "uuid": "^14.0.0",
    "@tootallnate/once": "^3.0.1"
  }
}
